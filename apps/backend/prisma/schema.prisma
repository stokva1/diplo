generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
  moduleFormat    = "cjs"
}

datasource db {
  provider = "postgresql"
}

model AuditLog {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  actorMembershipId String?  @map("actor_membership_id") @db.Uuid
  action            String   @db.VarChar(100)
  entityType        String   @map("entity_type") @db.VarChar(100)
  entityId          String   @map("entity_id") @db.Uuid
  oldValues         Json?    @map("old_values")
  newValues         Json?    @map("new_values")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actorMembership Membership?  @relation(fields: [actorMembershipId], references: [id], onUpdate: NoAction)
  organization    Organization @relation(fields: [organizationId], references: [id], onUpdate: NoAction)

  @@index([actorMembershipId], map: "idx_audit_logs_actor_membership_id")
  @@index([createdAt], map: "idx_audit_logs_created_at")
  @@index([entityType, entityId], map: "idx_audit_logs_entity")
  @@index([organizationId], map: "idx_audit_logs_organization_id")
  @@map("audit_logs")
}

model EmailVerificationToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expiresAt], map: "idx_email_verification_tokens_expires_at")
  @@index([userId], map: "idx_email_verification_tokens_user_id")
  @@map("email_verification_tokens")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model FileAttachment {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId         String    @map("organization_id") @db.Uuid
  uploadedByMembershipId String    @map("uploaded_by_membership_id") @db.Uuid
  fileName               String    @map("file_name") @db.VarChar(255)
  mimeType               String    @map("mime_type") @db.VarChar(100)
  fileSizeBytes          Int       @map("file_size_bytes")
  purpose                String    @default("OTHER") @db.VarChar(30)
  storageKey             String    @unique @map("storage_key") @db.VarChar(500)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  deletedAt              DateTime? @map("deleted_at") @db.Timestamptz(6)

  organization            Organization             @relation(fields: [organizationId], references: [id], onUpdate: NoAction)
  uploadedByMembership    Membership               @relation(fields: [uploadedByMembershipId], references: [id], onUpdate: NoAction)
  serviceEvents           ServiceEvent[]
  tripLogs                TripLog[]
  vehicleIssueAttachments VehicleIssueAttachment[]

  @@index([organizationId], map: "idx_file_attachments_organization_id")
  @@index([purpose], map: "idx_file_attachments_purpose")
  @@index([uploadedByMembershipId], map: "idx_file_attachments_uploaded_by_membership_id")
  @@map("file_attachments")
}

model Invitation {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  email          String    @db.VarChar(255)
  name           String?   @db.VarChar(255)
  tokenHash      String    @map("token_hash") @db.VarChar(255)
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(6)
  acceptedAt     DateTime? @map("accepted_at") @db.Timestamptz(6)
  cancelledAt    DateTime? @map("cancelled_at") @db.Timestamptz(6)
  createdById    String    @map("created_by_id") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  createdBy    Membership   @relation(fields: [createdById], references: [id], onUpdate: NoAction)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([createdById], map: "idx_invitations_created_by_id")
  @@index([email], map: "idx_invitations_email")
  @@index([organizationId], map: "idx_invitations_organization_id")
  @@map("invitations")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Membership {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           String   @default("MEMBER") @db.VarChar(20)
  status         String   @default("ACTIVE") @db.VarChar(20)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  auditLogs              AuditLog[]
  fileAttachments        FileAttachment[]
  invitations            Invitation[]
  organization           Organization     @relation(fields: [organizationId], references: [id], onUpdate: NoAction)
  user                   User             @relation(fields: [userId], references: [id], onUpdate: NoAction)
  cancelledReservations  Reservation[]    @relation("ReservationCancelledByMembership")
  reservations           Reservation[]    @relation("ReservationMembership")
  cancelledServiceEvents ServiceEvent[]   @relation("ServiceEventCancelledByMembership")
  createdServiceEvents   ServiceEvent[]   @relation("ServiceEventCreatedByMembership")
  tripLogs               TripLog[]
  reportedVehicleIssues  VehicleIssue[]   @relation("VehicleIssueReportedByMembership")
  resolvedVehicleIssues  VehicleIssue[]   @relation("VehicleIssueResolvedByMembership")
  managedVehicles        Vehicle[]

  @@unique([organizationId, userId], map: "uq_memberships_organization_user")
  @@map("memberships")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model OrganizationSettings {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId            String   @unique @map("organization_id") @db.Uuid
  tripLogRetentionMonths    Int      @default(60) @map("trip_log_retention_months")
  issuePhotoRetentionMonths Int      @default(24) @map("issue_photo_retention_months")
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                 DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("organization_settings")
}

model Organization {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @db.VarChar(255)
  ico          String?  @db.VarChar(20)
  contactEmail String?  @map("contact_email") @db.VarChar(255)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  auditLogs            AuditLog[]
  fileAttachments      FileAttachment[]
  invitations          Invitation[]
  memberships          Membership[]
  organizationSettings OrganizationSettings?
  vehicles             Vehicle[]

  @@map("organizations")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expiresAt], map: "idx_password_reset_tokens_expires_at")
  @@index([userId], map: "idx_password_reset_tokens_user_id")
  @@map("password_reset_tokens")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Reservation {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleId               String    @map("vehicle_id") @db.Uuid
  membershipId            String    @map("membership_id") @db.Uuid
  startAt                 DateTime  @map("start_at") @db.Timestamptz(6)
  endAt                   DateTime  @map("end_at") @db.Timestamptz(6)
  origin                  String    @db.VarChar(255)
  destination             String    @db.VarChar(255)
  purpose                 String
  status                  String    @default("ACTIVE") @db.VarChar(20)
  cancelledAt             DateTime? @map("cancelled_at") @db.Timestamptz(6)
  cancelledByMembershipId String?   @map("cancelled_by_membership_id") @db.Uuid
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  cancelledByMembership Membership?    @relation("ReservationCancelledByMembership", fields: [cancelledByMembershipId], references: [id], onUpdate: NoAction)
  membership            Membership     @relation("ReservationMembership", fields: [membershipId], references: [id], onUpdate: NoAction)
  vehicle               Vehicle        @relation(fields: [vehicleId], references: [id], onUpdate: NoAction)
  tripLog               TripLog?
  vehicleIssues         VehicleIssue[]

  @@index([cancelledByMembershipId], map: "idx_reservations_cancelled_by_membership_id")
  @@index([membershipId], map: "idx_reservations_membership_id")
  @@index([status], map: "idx_reservations_status")
  @@index([vehicleId, startAt, endAt], map: "idx_reservations_vehicle_time")
  @@map("reservations")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ServiceEvent {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleId               String    @map("vehicle_id") @db.Uuid
  createdByMembershipId   String    @map("created_by_membership_id") @db.Uuid
  title                   String    @db.VarChar(255)
  description             String?
  startAt                 DateTime  @map("start_at") @db.Timestamptz(6)
  endAt                   DateTime  @map("end_at") @db.Timestamptz(6)
  cost                    Decimal?  @db.Decimal(10, 2)
  invoiceFileId           String?   @map("invoice_file_id") @db.Uuid
  status                  String    @default("ACTIVE") @db.VarChar(20)
  cancelledAt             DateTime? @map("cancelled_at") @db.Timestamptz(6)
  cancelledByMembershipId String?   @map("cancelled_by_membership_id") @db.Uuid
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  cancelledByMembership Membership?     @relation("ServiceEventCancelledByMembership", fields: [cancelledByMembershipId], references: [id], onUpdate: NoAction)
  createdByMembership   Membership      @relation("ServiceEventCreatedByMembership", fields: [createdByMembershipId], references: [id], onUpdate: NoAction)
  invoiceFile           FileAttachment? @relation(fields: [invoiceFileId], references: [id], onUpdate: NoAction)
  vehicle               Vehicle         @relation(fields: [vehicleId], references: [id], onUpdate: NoAction)

  @@index([cancelledByMembershipId], map: "idx_service_events_cancelled_by_membership_id")
  @@index([createdByMembershipId], map: "idx_service_events_created_by_membership_id")
  @@index([invoiceFileId], map: "idx_service_events_invoice_file_id")
  @@index([status], map: "idx_service_events_status")
  @@index([vehicleId, startAt, endAt], map: "idx_service_events_vehicle_time")
  @@map("service_events")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model TripLog {
  id                      String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservationId           String   @unique @map("reservation_id") @db.Uuid
  odometerStartKm         Int      @map("odometer_start_km")
  odometerEndKm           Int      @map("odometer_end_km")
  distanceKm              Int?     @default(dbgenerated("(odometer_end_km - odometer_start_km)")) @map("distance_km")
  refueled                Boolean  @default(false)
  refuelingCost           Decimal? @map("refueling_cost") @db.Decimal(10, 2)
  refuelingReceiptFileId  String?  @map("refueling_receipt_file_id") @db.Uuid
  note                    String?
  completedByMembershipId String   @map("completed_by_membership_id") @db.Uuid
  completedAt             DateTime @default(now()) @map("completed_at") @db.Timestamptz(6)
  createdAt               DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt               DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  completedByMembership Membership      @relation(fields: [completedByMembershipId], references: [id], onUpdate: NoAction)
  refuelingReceiptFile  FileAttachment? @relation(fields: [refuelingReceiptFileId], references: [id], onUpdate: NoAction)
  reservation           Reservation     @relation(fields: [reservationId], references: [id], onUpdate: NoAction)

  @@index([completedByMembershipId], map: "idx_trip_logs_completed_by_membership_id")
  @@index([refuelingReceiptFileId], map: "idx_trip_logs_refueling_receipt_file_id")
  @@map("trip_logs")
}

model User {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email           String    @unique @db.VarChar(255)
  passwordHash    String    @map("password_hash") @db.VarChar(255)
  name            String    @db.VarChar(255)
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  memberships             Membership[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  @@map("users")
}

model VehicleIssueAttachment {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleIssueId   String   @map("vehicle_issue_id") @db.Uuid
  fileAttachmentId String   @map("file_attachment_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  fileAttachment FileAttachment @relation(fields: [fileAttachmentId], references: [id], onUpdate: NoAction)
  vehicleIssue   VehicleIssue   @relation(fields: [vehicleIssueId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([vehicleIssueId, fileAttachmentId], map: "uq_vehicle_issue_attachments_issue_file")
  @@index([fileAttachmentId], map: "idx_vehicle_issue_attachments_file_attachment_id")
  @@index([vehicleIssueId], map: "idx_vehicle_issue_attachments_vehicle_issue_id")
  @@map("vehicle_issue_attachments")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model VehicleIssue {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  vehicleId              String    @map("vehicle_id") @db.Uuid
  reservationId          String?   @map("reservation_id") @db.Uuid
  reportedByMembershipId String    @map("reported_by_membership_id") @db.Uuid
  description            String
  status                 String    @default("OPEN") @db.VarChar(20)
  resolvedByMembershipId String?   @map("resolved_by_membership_id") @db.Uuid
  resolvedAt             DateTime? @map("resolved_at") @db.Timestamptz(6)
  createdAt              DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  vehicleIssueAttachments VehicleIssueAttachment[]
  reportedByMembership    Membership               @relation("VehicleIssueReportedByMembership", fields: [reportedByMembershipId], references: [id], onUpdate: NoAction)
  reservation             Reservation?             @relation(fields: [reservationId], references: [id], onUpdate: NoAction)
  resolvedByMembership    Membership?              @relation("VehicleIssueResolvedByMembership", fields: [resolvedByMembershipId], references: [id], onUpdate: NoAction)
  vehicle                 Vehicle                  @relation(fields: [vehicleId], references: [id], onUpdate: NoAction)

  @@index([reportedByMembershipId], map: "idx_vehicle_issues_reported_by_membership_id")
  @@index([reservationId], map: "idx_vehicle_issues_reservation_id")
  @@index([resolvedByMembershipId], map: "idx_vehicle_issues_resolved_by_membership_id")
  @@index([status], map: "idx_vehicle_issues_status")
  @@index([vehicleId], map: "idx_vehicle_issues_vehicle_id")
  @@map("vehicle_issues")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model Vehicle {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId      String    @map("organization_id") @db.Uuid
  managerMembershipId String?   @map("manager_membership_id") @db.Uuid
  name                String    @db.VarChar(255)
  licensePlate        String    @map("license_plate") @db.VarChar(30)
  brand               String    @db.VarChar(100)
  model               String    @db.VarChar(100)
  vin                 String?   @db.VarChar(50)
  fuelType            String    @map("fuel_type") @db.VarChar(30)
  currentOdometerKm   Int       @map("current_odometer_km")
  status              String    @default("ACTIVE") @db.VarChar(30)
  note                String?
  archivedAt          DateTime? @map("archived_at") @db.Timestamptz(6)
  createdAt           DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  reservations      Reservation[]
  serviceEvents     ServiceEvent[]
  vehicleIssues     VehicleIssue[]
  managerMembership Membership?    @relation(fields: [managerMembershipId], references: [id], onUpdate: NoAction)
  organization      Organization   @relation(fields: [organizationId], references: [id], onUpdate: NoAction)

  @@unique([organizationId, licensePlate], map: "uq_vehicles_organization_license_plate")
  @@unique([organizationId, vin], map: "uq_vehicles_organization_vin_not_null", where: raw("(vin IS NOT NULL)"))
  @@index([managerMembershipId], map: "idx_vehicles_manager_membership_id")
  @@index([organizationId], map: "idx_vehicles_organization_id")
  @@index([status], map: "idx_vehicles_status")
  @@map("vehicles")
}
